INSTALLDIR = $(HOME)/.local
DATADIR    = $(HOME)/.local/share/nvim
STARTLOG   = $(DATADIR)/startup.log
SHELLRC    = $(shell echo $$SHELL | grep -q zsh && echo $(HOME)/.zshrc || echo $(HOME)/.bashrc)

define SHELL_CONFIG
# nvim-make-shell-start
export EDITOR=nvim
alias vi=nvim
alias vimark='nvim --startuptime $(STARTLOG) -c edit $(STARTLOG)'
export PATH=$(INSTALLDIR)/bin:$$PATH
# nvim-make-shell-end
endef
export SHELL_CONFIG

.PHONY: info shell

info:
	@echo "make shell      add configuration to zshrc/bashrc file ($(SHELLRC))"

shell:
	touch "$(SHELLRC)"
	awk '/# nvim-make-shell-start/{p=1} !p{print} /# nvim-make-shell-end/{p=0}' \
		"$(SHELLRC)" > "$(SHELLRC).tmp"
	echo "$$SHELL_CONFIG" >> "$(SHELLRC).tmp"
	mv "$(SHELLRC).tmp" "$(SHELLRC)"
